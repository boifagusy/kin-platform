## TERMUX ENVIRONMENT

PATHS:
PROJECT_ROOT: /data/data/com.termux/files/home/storage/kin_platform/
BACKEND:      /data/data/com.termux/files/home/storage/kin_platform/backend/
FRONTEND:     /data/data/com.termux/files/home/storage/kin_platform/frontend/
ANDROID:      /data/data/com.termux/files/home/storage/kin_platform/frontend/android/
DOCS:         /data/data/com.termux/files/home/storage/kin_platform/docs/

JAVA 21 SETUP:
export JAVA_HOME=/data/data/com.termux/files/usr/lib/jvm/java-21-openjdk
export PATH=$JAVA_HOME/bin:$PATH
java -version

ANDROID SDK SETUP:
export ANDROID_HOME=/data/data/com.termux/files/usr/lib/android-sdk
export PATH=$ANDROID_HOME/cmdline-tools/latest/bin:$PATH
export PATH=$ANDROID_HOME/platform-tools:$PATH

BUILD COMMANDS:
cd ~/storage/kin_platform/frontend
npm run build
npx cap sync android
npx cap build android

BACKEND COMMANDS:
cd ~/storage/kin_platform/backend
php artisan serve --host=127.0.0.1 --port=8000
php artisan queue:work
php artisan migrate:status
php artisan route:list | grep api

