<?php

namespace App\Services;

use App\Models\User;
use App\Models\CheckIn;
use App\Models\TrustedContact;
use App\Events\CheckInCompleted;
use Illuminate\Support\Facades\DB;

class CheckInService
{
    public function handle(array $data): array
    {
        $user = User::where('phone', $data['phone'])->first();

        if (!$user) {
            return ['success' => false, 'error' => 'User not found'];
        }

        // Verify active safety network exists
        $activeContacts = TrustedContact::where('user_id', $user->id)
            ->where('active', true)
            ->where('verified', true)
            ->count();

        if ($activeContacts === 0) {
            return ['success' => false, 'error' => 'Check-in unavailable. You must have at least one active verified trusted contact.'];
        }

        $checkIn = DB::transaction(function () use ($user, $data) {
            $checkIn = CheckIn::create([
                'user_id' => $user->id,
                'status' => $data['status'],
                'latitude' => $data['latitude'] ?? null,
                'longitude' => $data['longitude'] ?? null,
                'battery_level' => $data['battery_level'] ?? null,
                'checked_in_at' => now(),
            ]);

            $user->update(['last_checkin_at' => now()]);

            return $checkIn;
        });

        // Fire event - listeners handle score, cache, activity log
        event(new CheckInCompleted($user, $checkIn));

        return [
            'success' => true,
            'message' => 'Check-in recorded successfully',
            'data' => ['id' => $checkIn->id, 'checked_in_at' => $checkIn->checked_in_at],
        ];
    }
}
