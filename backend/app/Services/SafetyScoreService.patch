// Add this import at the top
use App\Services\DeviceTrustService;

// Update the getDeviceTrustFactor method
private function getDeviceTrustFactor(User $user): float
{
    try {
        $deviceTrustService = app(DeviceTrustService::class);
        $score = $deviceTrustService->getTrustScore($user);
        return $score / 100;
    } catch (\Exception $e) {
        Log::warning('Device trust factor calculation failed', [
            'user_id' => $user->id,
            'error' => $e->getMessage()
        ]);
        return 0.5; // Default fallback
    }
}
