<?php

namespace App\Services;

use App\Models\User;
use App\Models\PasswordReset;
use App\Mail\OtpMail;
use Illuminate\Support\Facades\Mail;
use Illuminate\Support\Facades\Hash;
use Illuminate\Support\Str;

class PasswordResetService
{
    /**
     * Generate and send OTP for password reset
     */
    public function sendResetOtp(string $email, string $phone = null): array
    {
        $user = User::where('email', $email)->first();

        if (!$user) {
            return [
                'success' => true,
                'message' => 'If an account exists, an OTP has been sent.'
            ];
        }

        // Generate 6-digit OTP
        $otp = str_pad(random_int(0, 999999), 6, '0', STR_PAD_LEFT);
        $phone = $user->phone;

        // Store in password_resets table
        PasswordReset::updateOrCreate(
            ['phone' => $phone],
            [
                'otp' => Hash::make($otp),
                'expires_at' => now()->addMinutes(10),
                'used' => false
            ]
        );

        // Send email
        try {
            Mail::to($user->email)->send(new OtpMail($otp, $user->name ?? 'User'));
            return [
                'success' => true,
                'message' => 'If an account exists, an OTP has been sent.'
            ];
        } catch (\Exception $e) {
            \Log::error('Failed to send OTP email: ' . $e->getMessage());
            return [
                'success' => false,
                'message' => 'Failed to send OTP. Please try again later.'
            ];
        }
    }

    /**
     * Verify OTP and mark as used
     */
    public function verifyOtp(string $phone, string $otp): array
    {
        $reset = PasswordReset::where('phone', $phone)
            ->where('expires_at', '>', now())
            ->where('used', false)
            ->first();

        if (!$reset) {
            return [
                'success' => false,
                'message' => 'No valid OTP found. Please request a new one.'
            ];
        }

        if (!Hash::check($otp, $reset->otp)) {
            return [
                'success' => false,
                'message' => 'Invalid OTP. Please try again.'
            ];
        }

        // Mark OTP as used immediately
        $reset->update(['used' => true]);

        return [
            'success' => true,
            'message' => 'OTP verified successfully.'
        ];
    }

    /**
     * Reset PIN using verified OTP
     */
    public function resetPin(string $phone, string $otp, string $newPin): array
    {
        $verifyResult = $this->verifyOtp($phone, $otp);

        if (!$verifyResult['success']) {
            return $verifyResult;
        }

        $user = User::where('phone', $phone)->first();

        if (!$user) {
            return [
                'success' => false,
                'message' => 'User not found.'
            ];
        }

        // Update PIN hash
        $user->update([
            'login_pin_hash' => Hash::make($newPin)
        ]);

        return [
            'success' => true,
            'message' => 'PIN reset successfully.'
        ];
    }
}
