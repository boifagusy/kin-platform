function EmergencyModal({
  onConfirm,
  onCancel
}) {
  return (
    <div style={{
      position: "fixed",
      inset: 0,
      background: "rgba(0,0,0,0.5)",
      display: "flex",
      alignItems: "center",
      justifyContent: "center",
      zIndex: 999
    }}>
      <div style={{
        background: "white",
        borderRadius: 24,
        padding: 24,
        width: "90%",
        maxWidth: 360
      }}>
        <h2 style={{
          color: "#DC3545",
          marginBottom: 10
        }}>
          Emergency Alert
        </h2>

        <p style={{
          color: "#6b7280"
        }}>
          Send SOS alert to your trusted contacts?
        </p>

        <div style={{
          display: "flex",
          gap: 12,
          marginTop: 24
        }}>
          <button
            onClick={onCancel}
            style={{
              flex: 1,
              padding: 14,
              borderRadius: 12,
              border: "1px solid #ddd",
              background: "white"
            }}
          >
            Cancel
          </button>

          <button
            onClick={onConfirm}
            style={{
              flex: 1,
              padding: 14,
              borderRadius: 12,
              border: "none",
              background: "#DC3545",
              color: "white",
              fontWeight: "bold"
            }}
          >
            Send SOS
          </button>
        </div>
      </div>
    </div>
  );
}

export default EmergencyModal;
