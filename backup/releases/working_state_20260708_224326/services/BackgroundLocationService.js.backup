import locationTracker from './locationTracker';
import { getBatteryLevel } from '../utils/location';

class BackgroundLocationService {
  constructor() {
    this.isRunning = false;
    this.intervalId = null;
    this.phone = null;
    this.lastSendTime = 0;
    this.sendInterval = 60000; // 60 seconds
    this.collectInterval = 10000; // 10 seconds
    this.pendingLocations = [];
    this.isOnline = navigator.onLine;
    
    // Listen for online/offline events
    window.addEventListener('online', () => {
      this.isOnline = true;
      this.syncPendingLocations();
    });
    
    window.addEventListener('offline', () => {
      this.isOnline = false;
    });
  }

  start(phone) {
    if (!phone) {
      console.error('BackgroundLocationService: Phone required');
      return;
    }

    if (this.isRunning) {
      console.log('BackgroundLocationService: Already running');
      return;
    }

    this.phone = phone;
    this.isRunning = true;

    console.log('BackgroundLocationService: Starting...');

    // Start location tracking
    locationTracker.startTracking(phone);

    // Start collecting and sending location periodically
    this.intervalId = setInterval(() => {
      this.collectAndSend();
    }, this.collectInterval);

    // Also collect on visibility change
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        // Force a collection when app comes to foreground
        this.collectAndSend();
      }
    });

    console.log('BackgroundLocationService: Started');
  }

  stop() {
    if (this.intervalId) {
      clearInterval(this.intervalId);
      this.intervalId = null;
    }

    locationTracker.stopTracking();
    this.isRunning = false;
    console.log('BackgroundLocationService: Stopped');
  }

  async collectAndSend() {
    try {
      const location = locationTracker.getLocationWithFreshness();
      
      if (!location) {
        console.log('BackgroundLocationService: No location yet');
        return;
      }

      // Only send if location is fresh (less than 30 seconds old)
      if (location.age > 30000) {
        console.log('BackgroundLocationService: Location is stale, skipping');
        return;
      }

      // Check if enough time has passed since last send
      const now = Date.now();
      if (now - this.lastSendTime < this.sendInterval) {
        // Only update if accuracy improved significantly
        const lastLocation = this.getLastSentLocation();
        if (lastLocation && location.accuracy >= lastLocation.accuracy) {
          return;
        }
      }

      // Get battery level
      let battery = null;
      try {
        battery = await getBatteryLevel();
      } catch (err) {
        console.warn('BackgroundLocationService: Battery error:', err);
      }

      const payload = {
        phone: this.phone,
        latitude: location.latitude,
        longitude: location.longitude,
        accuracy: location.accuracy,
        speed: location.speed || 0,
        heading: location.heading || 0,
        timestamp: Date.now(),
        battery: battery,
        network: this.getNetworkType(),
        source: 'background',
      };

      if (this.isOnline) {
        await this.sendLocation(payload);
      } else {
        this.pendingLocations.push(payload);
        console.log('BackgroundLocationService: Offline, stored location');
      }

      this.lastSendTime = now;
    } catch (error) {
      console.error('BackgroundLocationService: Error:', error);
    }
  }

  async sendLocation(payload) {
    try {
      const response = await fetch('http://127.0.0.1:8000/api/v1/location', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data = await response.json();
      console.log('BackgroundLocationService: Location sent');
      
      // Store last sent location
      this.setLastSentLocation(payload);
      
      return data;
    } catch (error) {
      console.error('BackgroundLocationService: Send failed:', error);
      this.pendingLocations.push(payload);
      return null;
    }
  }

  async syncPendingLocations() {
    if (this.pendingLocations.length === 0) return;

    console.log(`BackgroundLocationService: Syncing ${this.pendingLocations.length} pending locations`);

    const toSend = [...this.pendingLocations];
    this.pendingLocations = [];

    for (const location of toSend) {
      await this.sendLocation(location);
    }
  }

  getNetworkType() {
    const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
    if (connection) {
      return connection.effectiveType || connection.type || 'unknown';
    }
    return 'unknown';
  }

  getLastSentLocation() {
    try {
      const data = localStorage.getItem('kin_last_sent_location');
      return data ? JSON.parse(data) : null;
    } catch {
      return null;
    }
  }

  setLastSentLocation(location) {
    try {
      localStorage.setItem('kin_last_sent_location', JSON.stringify(location));
    } catch (err) {
      console.warn('BackgroundLocationService: Could not store last location:', err);
    }
  }

  getStatus() {
    return {
      isRunning: this.isRunning,
      phone: this.phone,
      pendingLocations: this.pendingLocations.length,
      lastSendTime: this.lastSendTime,
      isOnline: this.isOnline,
    };
  }
}

// Singleton
const backgroundLocation = new BackgroundLocationService();
export default backgroundLocation;
