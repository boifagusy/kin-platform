import { useState } from "react";
import { FaShieldAlt, FaLock } from "react-icons/fa";
import { useNavigate } from "react-router-dom";

import NumberRegisteredPopup from "../../components/NumberRegisteredPopup";
import NumberNotRegisteredPopup from "../../components/NumberNotRegisteredPopup";

function PhoneEntryScreen() {
const [phone, setPhone] = useState("");
const [loading, setLoading] = useState(false);
const [error, setError] = useState("");

const [maskedPhone, setMaskedPhone] = useState("");

const [showRegisteredPopup, setShowRegisteredPopup] =
useState(false);

const [showNotRegisteredPopup, setShowNotRegisteredPopup] =
useState(false);

const navigate = useNavigate();

const isValid = phone.length === 10;

async function handleContinue() {
try {
setLoading(true);
setError("");

  const response = await fetch(
    "http://127.0.0.1:8000/api/v1/auth/confirm-phone",
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        phone: `+234${phone}`,
      }),
    }
  );

  const data = await response.json();

  setMaskedPhone(data.masked_phone);

  if (data.exists) {
    setShowRegisteredPopup(true);
  } else {
    setShowNotRegisteredPopup(true);
  }
} catch (err) {
  console.error(err);

  setError(
    "Unable to connect to Kin server."
  );
} finally {
  setLoading(false);
}

}

return (
<div
style={{
minHeight: "100vh",
background:
"linear-gradient(180deg,#F8FBF9 0%,#EDF5F0 100%)",
display: "flex",
alignItems: "center",
justifyContent: "center",
padding: "24px",
}}
>
<div
style={{
width: "100%",
maxWidth: "430px",
background: "#FFFFFF",
borderRadius: "36px",
padding: "40px 28px",
boxShadow:
"0 20px 40px rgba(26,86,50,0.10)",
}}
>
<div
style={{
display: "flex",
justifyContent: "center",
marginBottom: "24px",
}}
>
<div
style={{
width: "140px",
height: "140px",
borderRadius: "50%",
background: "#FFFFFF",
display: "flex",
alignItems: "center",
justifyContent: "center",
boxShadow:
"0 20px 40px rgba(26,86,50,0.12)",
}}
>
<FaShieldAlt
size={60}
color="#1A5632"
/>
</div>
</div>

    <h1
      style={{
        textAlign: "center",
        fontSize: "48px",
        color: "#1A5632",
        fontWeight: "800",
        margin: 0,
      }}
    >
      Kin
    </h1>

    <p
      style={{
        textAlign: "center",
        color: "#6B7280",
        marginTop: "14px",
        marginBottom: "40px",
        fontSize: "16px",
        lineHeight: "26px",
      }}
    >
      Stay connected to the
      <br />
      people who matter most.
    </p>

    <div
      style={{
        fontWeight: "700",
        marginBottom: "12px",
        color: "#111827",
      }}
    >
      Mobile Number
    </div>

    <div
      style={{
        display: "flex",
        height: "68px",
        border: "2px solid #E5E7EB",
        borderRadius: "20px",
        overflow: "hidden",
        background: "#FFFFFF",
      }}
    >
      <div
        style={{
          width: "90px",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          background: "#F9FAFB",
          fontWeight: "700",
          color: "#1A5632",
        }}
      >
        +234
      </div>

      <input
        type="tel"
        value={phone}
        maxLength={10}
        placeholder="8012345678"
        onChange={(e) =>
          setPhone(
            e.target.value.replace(
              /\D/g,
              ""
            )
          )
        }
        style={{
          flex: 1,
          border: "none",
          outline: "none",
          padding: "0 18px",
          fontSize: "18px",
          background: "transparent",
        }}
      />
    </div>

    {error && (
      <div
        style={{
          color: "#DC2626",
          marginTop: "12px",
          textAlign: "center",
          fontSize: "14px",
        }}
      >
        {error}
      </div>
    )}

    <div
      style={{
        display: "flex",
        alignItems: "center",
        gap: "8px",
        marginTop: "16px",
        color: "#6B7280",
        fontSize: "14px",
      }}                                              >
      <FaLock size={12} />
      Secure & Private
    </div>                                        
    <button                                             disabled={!isValid || loading}
      onClick={handleContinue}                          style={{
        width: "100%",                                    height: "64px",
        marginTop: "24px",                                border: "none",
        borderRadius: "20px",                             background:
          !isValid || loading
            ? "#B7D4BF"                                       : "linear-gradient(90deg,#1A5632,#3A7D44)",
        color: "#FFFFFF",
        fontSize: "18px",
        fontWeight: "700",
        cursor: "pointer",
      }}
    >
      {loading
        ? "Checking..."
        : "Continue"}
    </button>

    <div
      style={{
        marginTop: "24px",
        textAlign: "center",
        color: "#6B7280",
        fontSize: "14px",
        lineHeight: "22px",
      }}                                              >
      Your location is never shared
      <br />                                            without your permission.                        </div>

<NumberRegisteredPopup
open={showRegisteredPopup}
phone={maskedPhone}
onClose={() =>
setShowRegisteredPopup(false)
}
onContinue={() => {
setShowRegisteredPopup(false);

navigate("/login-pin", {
  state: {
    phone: `+234${phone}`,
  },
});

}}
/>

<NumberNotRegisteredPopup
open={showNotRegisteredPopup}
phone={maskedPhone}
onClose={() =>
setShowNotRegisteredPopup(false)
}
onContinue={() => {
setShowNotRegisteredPopup(false);

navigate("/create-pin", {
  state: {
    phone: `+234${phone}`,
  },
});

}}
/>

</div>
</div>

);
}
export default PhoneEntryScreen;
