import { useState, useEffect } from "react";
import { useLocation, useNavigate } from "react-router-dom";
import { FaArrowLeft, FaClock, FaBell, FaSave } from "react-icons/fa";

const API_BASE = import.meta.env.VITE_API_URL || "http://localhost:8000/api/v1";

function CheckInSettingsScreen() {
  const location = useLocation();
  const navigate = useNavigate();
  const phone = location.state?.phone || localStorage.getItem("kin_phone") || "";

  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [settings, setSettings] = useState({
    checkin_time: "21:00",
    grace_minutes: 15,
    enabled: true,
  });
  const [error, setError] = useState("");

  useEffect(() => {
    loadSettings();
  }, []);

  const loadSettings = async () => {
    try {
      setLoading(true);
      const response = await fetch(`${API_BASE}/checkin-settings?phone=${encodeURIComponent(phone)}`, {
        method: "GET",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${localStorage.getItem("kin_token")}`,
        },
      });
      const data = await response.json();
      if (data.success) {
        setSettings(data.data || settings);
      }
    } catch (err) {
      console.error("Error loading settings:", err);
    } finally {
      setLoading(false);
    }
  };

  const handleSave = async () => {
    try {
      setSaving(true);
      setError("");
      const response = await fetch(`${API_BASE}/checkin-settings`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${localStorage.getItem("kin_token")}`,
        },
        body: JSON.stringify({
          phone,
          ...settings,
        }),
      });
      const data = await response.json();
      if (data.success) {
        navigate("/dashboard", { state: { phone } });
      } else {
        setError(data.message || "Failed to save settings");
      }
    } catch (err) {
      setError("Unable to connect to Kin server");
    } finally {
      setSaving(false);
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-green-600 mx-auto"></div>
          <p className="mt-4 text-gray-600">Loading settings...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-4">
      <div className="max-w-md mx-auto">
        <button
          onClick={() => navigate("/dashboard", { state: { phone } })}
          className="text-gray-500 hover:text-gray-700 mb-4"
        >
          <FaArrowLeft />
        </button>

        <h1 className="text-2xl font-bold text-gray-800 mb-6">Check-In Settings</h1>

        {error && (
          <div className="bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg p-3 mb-4">
            {error}
          </div>
        )}

        <div className="bg-white rounded-xl shadow-sm p-4 mb-4">
          <div className="flex items-center gap-3 mb-4">
            <FaClock className="text-green-600 text-xl" />
            <div>
              <label className="block text-sm font-medium text-gray-700">Check-In Time</label>
              <input
                type="time"
                value={settings.checkin_time}
                onChange={(e) => setSettings({ ...settings, checkin_time: e.target.value })}
                className="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              />
            </div>
          </div>

          <div className="flex items-center gap-3 mb-4">
            <FaBell className="text-green-600 text-xl" />
            <div>
              <label className="block text-sm font-medium text-gray-700">Grace Period (minutes)</label>
              <input
                type="number"
                min="0"
                max="60"
                value={settings.grace_minutes}
                onChange={(e) => setSettings({ ...settings, grace_minutes: parseInt(e.target.value) || 15 })}
                className="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              />
            </div>
          </div>

          <div className="flex items-center justify-between">
            <span className="text-sm text-gray-700">Enable Check-Ins</span>
            <button
              onClick={() => setSettings({ ...settings, enabled: !settings.enabled })}
              className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${
                settings.enabled ? "bg-green-600" : "bg-gray-300"
              }`}
            >
              <span
                className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${
                  settings.enabled ? "translate-x-6" : "translate-x-1"
                }`}
              />
            </button>
          </div>
        </div>

        <button
          onClick={handleSave}
          disabled={saving}
          className={`w-full py-3 rounded-lg font-semibold transition-colors flex items-center justify-center gap-2 ${
            saving ? "bg-gray-400 cursor-not-allowed" : "bg-green-600 text-white hover:bg-green-700"
          }`}
        >
          <FaSave />
          {saving ? "Saving..." : "Save Settings"}
        </button>
      </div>
    </div>
  );
}

export default CheckInSettingsScreen;
