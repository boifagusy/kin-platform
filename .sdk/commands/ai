#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

if [ ! -t 0 ] && [ $# -eq 0 ]; then
    CONTENT="$(cat)"
    source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
    _clipboard_save_copy "$CONTENT" "pipe"
    exit $?
fi

source "$SDK_ROOT/core/lib/common.sh"
source "$SDK_ROOT/core/lib/yaml.sh"
source "$SDK_ROOT/core/lib/state.sh"
source "$SDK_ROOT/core/lib/plugin.sh"

[ $# -eq 0 ] && { ./.sdk/commands/ai work 2>/dev/null; exit 0; }

COMMAND="$1"; shift

case "$COMMAND" in
    work|status|doctor|install) execute_plugin "$COMMAND" ;;
    copy|clip)
        source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
        # No args = save everything
        [ $# -eq 0 ] && { clipboard_save_all; exit $?; }
        case "$1" in
            status)  clipboard_status ;;
            file)    shift; clipboard_copy_file "$1" ;;
            history) clipboard_history "${2:-10}" ;;
            last)    clipboard_last ;;
            *)       shift; clipboard_copy "manual" "$*" ;;
        esac ;;
    restore)   bash "$SDK_ROOT/engines/restore/engine.sh" "$@" ;;
    governance|guard)
        source "$SDK_ROOT/engines/governance/engine.sh" 2>/dev/null
        governance_check "${1:-unknown}" "${2:-}" ;;
    session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate|help|tutorial|examples|explain|contract)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}"
        ;;
    investigate)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}"
        ;;
    certify)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}"
        ;;
    certify)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}"
        ;;
    certify)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}"
        ;;
    certify|task)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}" ;;
    plugins) list_plugins ;;
    *) echo "Unknown: $COMMAND" ;;
esac
