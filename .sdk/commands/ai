#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

# Pipe detection
if [ ! -t 0 ] && [ $# -eq 0 ]; then
    CONTENT="$(cat)"
    source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
    clipboard_copy "pipe" "$CONTENT" 2>/dev/null
    exit $?
fi

source "$SDK_ROOT/core/lib/common.sh"
source "$SDK_ROOT/core/lib/yaml.sh"
source "$SDK_ROOT/core/lib/state.sh"
source "$SDK_ROOT/core/lib/plugin.sh"

GOVERNANCE_ENGINE="$SDK_ROOT/engines/governance/engine.sh"
source "$SDK_ROOT/engines/governance/levels.sh" 2>/dev/null

[ $# -eq 0 ] && { ./.sdk/commands/ai work 2>/dev/null; exit 0; }

COMMAND="$1"; shift

# Level 0 bypasses governance
if [ "$COMMAND" != "clip" ]; then
    CMD_LEVEL=$(governance_level "$COMMAND")
    if [ "$CMD_LEVEL" -gt 0 ] && [ -f "$GOVERNANCE_ENGINE" ]; then
        source "$GOVERNANCE_ENGINE" 2>/dev/null
        governance_check "$COMMAND" "${1:-}" || exit 1
    fi
fi

case "$COMMAND" in
    status|doctor|install|work|contract|task)
        execute_plugin "$COMMAND" ;;
    restore)
        bash "$SDK_ROOT/engines/restore/engine.sh" "$@" ;;
    governance|guard)
        source "$GOVERNANCE_ENGINE" 2>/dev/null
        governance_check "${1:-unknown}" "${2:-}" ;;
    clip)
        source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
        case "${1:-status}" in
            status)  clipboard_status ;;
            copy)    shift; clipboard_copy "manual" "$*" ;;
            file)    shift; clipboard_copy_file "$1" ;;
            history) clipboard_history "${2:-10}" ;;
            last)    clipboard_last ;;
            *)       clipboard_status ;;
        esac ;;
    session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate|help|tutorial|examples|explain)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}" ;;
    plugins) list_plugins ;;
    *) echo "Unknown: $COMMAND" ;;
esac
