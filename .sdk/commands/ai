#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

source "$SDK_ROOT/core/lib/common.sh"
source "$SDK_ROOT/core/lib/yaml.sh"
source "$SDK_ROOT/core/lib/state.sh"
source "$SDK_ROOT/core/lib/plugin.sh"

if [ $# -eq 0 ]; then
    ./.sdk/commands/ai work 2>/dev/null || {
        SDK_VERSION=$(read_yaml "$SDK_ROOT/sdk.yaml" "version")
        cat << HELP
KIN Engineering SDK v${SDK_VERSION}

Commands:
  work       Daily engineering dashboard
  status     Show project status
  doctor     Run environment diagnostics
  validate   Validate system health
  session    Manage AI sessions
  role       Manage AI roles
  gate       Gate management
  brick      Brick management
  workflow   Workflow management
  event      Event system
  audit      Audit trail
  knowledge  Knowledge base
  git        Git operations
  github     GitHub operations
  release    Release management
  install    Install SDK into a project
  plugins    List available plugins

Environment: Termux-first
HELP
    }
    exit 0
fi

COMMAND="$1"
ACTION="${2:-main}"
ARG="${3:-}"

case "$COMMAND" in
    status|doctor|install|work)
        execute_plugin "$COMMAND" ;;
    session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate)
        execute_plugin "$COMMAND" && main "$ACTION" "$ARG" ;;
    plugins)
        list_plugins ;;
    *)
        echo "Unknown command: $COMMAND"
        echo "Run 'ai' for help"
        exit 1 ;;
esac
