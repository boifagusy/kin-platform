#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

# Pipe detection
if [ ! -t 0 ] && [ $# -eq 0 ]; then
    CONTENT="$(cat)"
    source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
    clipboard_copy "pipe" "$CONTENT" 2>/dev/null
    exit $?
fi

source "$SDK_ROOT/core/lib/common.sh"
source "$SDK_ROOT/core/lib/yaml.sh"
source "$SDK_ROOT/core/lib/state.sh"
source "$SDK_ROOT/core/lib/plugin.sh"

[ $# -eq 0 ] && { ./.sdk/commands/ai work 2>/dev/null; exit 0; }

COMMAND="$1"; shift

case "$COMMAND" in
    status|doctor|install|work)
        execute_plugin "$COMMAND" ;;
    restore)
        # Direct engine execution — no plugin wrapper
        bash "$SDK_ROOT/engines/restore/engine.sh" "$@" ;;
    clip)
        execute_plugin "$COMMAND" && main "$@" ;;
    session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate|help|tutorial|examples|explain)
        execute_plugin "$COMMAND" && main "${1:-main}" "${2:-}" ;;
    plugins) list_plugins ;;
    *) echo "Unknown: $COMMAND" ;;
esac
