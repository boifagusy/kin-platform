#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

# ── KERNEL: Load state first (mandatory) ──
source "$SDK_ROOT/kernel/kernel.sh" 2>/dev/null

# ── Pipe detection ──
if [ ! -t 0 ] && [ $# -eq 0 ]; then
    CONTENT="$(cat)"
    source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
    _clipboard_save_copy "$CONTENT" "pipe" 2>/dev/null
    exit $?
fi

source "$SDK_ROOT/kernel/common.sh" 2>/dev/null
source "$SDK_ROOT/kernel/registry.sh" 2>/dev/null
source "$SDK_ROOT/engines/governance/levels.sh" 2>/dev/null

[ $# -eq 0 ] && { kernel_ai_startup; exit 0; }

COMMAND="$1"; shift

# ── Resolve plugin ──
PLUGIN_FILE="$SDK_ROOT/commands/plugins/${COMMAND}.sh"
[ ! -f "$PLUGIN_FILE" ] && { echo "Unknown: $COMMAND"; exit 1; }

# ── Governance check ──
CMD_LEVEL=$(governance_level "$COMMAND" 2>/dev/null || echo "0")
if [ "$CMD_LEVEL" != "0" ] && [ -f "$SDK_ROOT/engines/governance/engine.sh" ]; then
    source "$SDK_ROOT/engines/governance/engine.sh" 2>/dev/null
    governance_check "$COMMAND" "${1:-}" || exit 1
fi

# ── Execute ──
source "$PLUGIN_FILE" 2>/dev/null
if type main >/dev/null 2>&1; then
    main "${1:-main}" "${2:-}"
else
    echo "Plugin error: $COMMAND"
fi
