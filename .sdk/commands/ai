#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

source "$SDK_ROOT/core/lib/common.sh"
source "$SDK_ROOT/core/lib/yaml.sh"
source "$SDK_ROOT/core/lib/state.sh"
source "$SDK_ROOT/core/lib/plugin.sh"

# Detect --copy flag globally
HAS_COPY=false
for arg in "$@"; do [ "$arg" = "--copy" ] && HAS_COPY=true; done

if [ $# -eq 0 ]; then
    ./.sdk/commands/ai work 2>/dev/null
    exit 0
fi

COMMAND="$1"
ACTION="${2:-main}"
ARG="${3:-}"

# Remove --copy from args for plugin
FILTERED_ARGS=()
for a in "$@"; do [ "$a" != "--copy" ] && FILTERED_ARGS+=("$a"); done
set -- "${FILTERED_ARGS[@]}"

# Execute with optional clipboard capture
if $HAS_COPY && [ "$COMMAND" != "clip" ]; then
    # Run command and capture output
    OUTPUT=$(case "$COMMAND" in
        status|doctor|install|work) execute_plugin "$COMMAND" 2>&1 ;;
        session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate|help|tutorial|examples|explain|clip)
            execute_plugin "$COMMAND" && main "$ACTION" "$ARG" 2>&1 ;;
        plugins) list_plugins 2>&1 ;;
        *) echo "Unknown: $COMMAND" ;;
    esac)
    
    echo "$OUTPUT"
    
    # Copy to clipboard
    if [ -f "$SDK_ROOT/engines/clipboard/engine.sh" ]; then
        source "$SDK_ROOT/engines/clipboard/engine.sh" 2>/dev/null
        echo "$OUTPUT" | clipboard_copy "$COMMAND" 2>/dev/null
    fi
else
    case "$COMMAND" in
        status|doctor|install|work)
            execute_plugin "$COMMAND" ;;
        clip|session|role|gate|brick|workflow|event|audit|knowledge|git|github|release|validate|help|tutorial|examples|explain)
            execute_plugin "$COMMAND" && main "$ACTION" "$ARG" ;;
        plugins) list_plugins ;;
        *) echo "Unknown: $COMMAND" ;;
    esac
fi
