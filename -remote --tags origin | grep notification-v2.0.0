[32m+[m[32m    Route::get('/{id}', [App\Http\Controllers\Admin\AnalyticsController::class, 'notificationShow'])->name('admin.analytics.notifications.show');[m
[32m+[m[32m    Route::post('/{id}/retry', [App\Http\Controllers\Admin\AnalyticsController::class, 'notificationRetry'])->name('admin.analytics.notifications.retry');[m
[32m+[m[32m    Route::post('/retry-bulk', [App\Http\Controllers\Admin\AnalyticsController::class, 'notificationRetryBulk'])->name('admin.analytics.notifications.retry-bulk');[m
[32m+[m[32m});[m
[32m+[m
[32m+[m[32m// N10: Automation Dashboard (deferred from N9)[m
