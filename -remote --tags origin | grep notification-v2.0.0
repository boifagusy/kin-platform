[32m+[m
[32m+[m[32mclass AutomationController extends Controller[m
[32m+[m[32m{[m
[32m+[m[32m    public function logs(Request $request)[m
[32m+[m[32m    {[m
[32m+[m[32m        // Read automation execution logs from Laravel log[m
[32m+[m[32m        $logPath = storage_path('logs/laravel.log');[m
[32m+[m[32m        $logs = [];[m
[32m+[m
[32m+[m[32m        if (file_exists($logPath)) {[m
[32m+[m[32m            $lines = file($logPath, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);[m
[32m+[m[32m            $automationLines = array_filter($lines, fn($l) => str_contains($l, '[N9]'));[m
[32m+[m[32m            $recent = array_slice(array_reverse($automationLines), 0, 100);[m
[32m+[m
[32m+[m[32m            foreach ($recent as $line) {[m
[32m+[m[32m                if (preg_match('/\[(.*?)\].*?\{.*"rule":"(.*?)".*"event":"(.*?)".*"user_id":(.*?)[,}]/', $line, $m)) {[m
[32m+[m[32m                    $logs[] = [[m
[32m+[m[32m                        'timestamp' => $m[1],[m
[32m+[m[32m                        'rule' => $m[2],[m
[32m+[m[32m                        'event' => $m[3],[m
[32m+[m[32m                        'user_id' => $m[4] !== 'null' ? (int) $m[4] : null,[m
[32m+[m[32m                    ];[m
[32m+[m[32m                }[m
[32m+[m[32m            }[m
[32m+[m[32m        }[m
[32m+[m
[32m+[m[32m        return view('admin.automation.logs', ['logs' => $logs]);[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    public function test(Request $request)[m
[32m+[m[32m    {[m
[32m+[m[32m        $eventType = $request->input('event_type', 'sos_triggered');[m
[32m+[m[32m        $userId = $request->input('user_id');[m
[32m+[m
[32m+[m[32m        $automation = new AutomationService([m
[32m+[m[32m            new RateLimiter(),[m
[32m+[m[32m            new QuietHoursResolver(),[m
[32m+[m[32m            new ChannelFallbackResolver(),[m
[32m+[m[32m            app(NotificationDriverManager::class),[m
[32m+[m[32m        );[m
[32m+[m
[32m+[m[32m        $payload = [[m
[32m+[m[32m            'event_type' => $eventType,[m
[32m+[m[32m            'user_id' => $userId,[m
[32m+[m[32m            'incident_type' => $request->input('incident_type', 'test'),[m
[32m+[m[32m        ];[m
[32m+[m
[32m+[m[32m        try {[m
[32m+[m[32m            $automation->evaluate($eventType, $payload);[m
[32m+[m[32m            return response()->json(['success' => true, 'message' => "Rule evaluation triggered for: {$eventType}"]);[m
[32m+[m[32m        } catch (\Exception $e) {[m
[32m+[m[32m            return response()->json(['success' => false, 'error' => $e->getMessage()], 500);[m
[32m+[m[32m        }[m
[32m+[m[32m    }[m
[32m+[m[32m}[m
