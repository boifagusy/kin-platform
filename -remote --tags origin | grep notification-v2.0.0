[36m@@ -0,0 +1,38 @@[m
[32m+[m[32m# KIN Notification Platform v2.0[m
[32m+[m
[32m+[m[32m## Architecture[m
[32m+[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mBusiness Event → NotificationService → Database → Broadcast (N3) → Clients[m
[32m+[m[32m→ AutomationService (N9) → Rules → Drivers[m
[32m+[m[32m→ AnalyticsService (N7) → Dashboard[m
[32m+[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m## Bricks[m
[32m+[m
[32m+[m[32m| Brick | Name | Status |[m
[32m+[m[32m|-------|------|--------|[m
[32m+[m[32m| N1 | Unified Notification Center | ✅ |[m
[32m+[m[32m| N2 | In-App Notification Inbox | ✅ |[m
[32m+[m[32m| N3 | Real-Time Notifications (Reverb) | ✅ |[m
[32m+[m[32m| N4 | Popup Manager | ✅ |[m
[32m+[m[32m| N5 | Toast Manager | ✅ |[m
[32m+[m[32m| N6 | User Notification Preferences | ✅ |[m
[32m+[m[32m| N7 | Notification Analytics & Management | ✅ |[m
[32m+[m[32m| N8 | Read/Unread Synchronization | ✅ |[m
[32m+[m[32m| N9 | Notification Automation & Rules Engine | ✅ |[m
[32m+[m[32m| N10 | Production Hardening | ✅ |[m
[32m+[m
[32m+[m[32m## API Overview[m
[32m+[m
[32m+[m[32mSee `routes/api.php` and `routes/admin.php` for full route list.[m
[32m+[m
[32m+[m[32mKey endpoints:[m
[32m+[m[32m- `GET /api/v1/notifications` — User notifications[m
[32m+[m[32m- `GET /api/v1/notifications/unread-count` — Unread count[m
[32m+[m[32m- `POST /api/v1/notifications/read-all` — Mark all read[m
[32m+[m[32m- `GET /api/v1/preferences/notifications` — User preferences[m
[32m+[m[32m- `GET /admin/analytics/notifications` — Admin analytics[m
[32m+[m[32m- `GET /admin/automation/logs` — Automation execution log[m
