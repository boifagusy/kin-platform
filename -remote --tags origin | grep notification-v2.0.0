[32m+[m[32m    Route::get('/logs', [App\Http\Controllers\Admin\AutomationController::class, 'logs'])->name('admin.automation.logs');[m
[32m+[m[32m    Route::post('/test', [App\Http\Controllers\Admin\AutomationController::class, 'test'])->name('admin.automation.test');[m
[32m+[m[32m});[m
