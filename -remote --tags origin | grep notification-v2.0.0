[32m+[m[32m## API Overview[m
[32m+[m
[32m+[m[32m### User Endpoints (Sanctum auth)[m
[32m+[m[32m- `GET /api/v1/notifications` — User notifications[m
[32m+[m[32m- `GET /api/v1/notifications/unread-count` — Unread count[m
[32m+[m[32m- `POST /api/v1/notifications/read-all` — Mark all read[m
[32m+[m[32m- `POST /api/v1/notifications/{id}/read` — Mark single read[m
[32m+[m[32m- `GET /api/v1/notifications/badge` — Badge count[m
[32m+[m[32m- `GET /api/v1/preferences/notifications` — Get preferences[m
[32m+[m[32m- `PUT /api/v1/preferences/notifications` — Update preferences[m
[32m+[m
[32m+[m[32m### Admin Endpoints (admin.auth middleware)[m
[32m+[m[32m- `GET /admin/analytics` — Platform dashboard[m
[32m+[m[32m- `GET /admin/analytics/notifications` — Notification analytics[m
[32m+[m[32m- `GET /admin/analytics/notifications/trends` — Daily/weekly trends[m
[32m+[m[32m- `GET /admin/analytics/notifications/channels` — Channel breakdown[m
[32m+[m[32m- `GET /admin/analytics/notifications/failures` — Failure summary[m
[32m+[m[32m- `GET /admin/analytics/notifications/manage` — Search/filter[m
[32m+[m[32m- `POST /admin/analytics/notifications/{id}/retry` — Retry single[m
[32m+[m[32m- `POST /admin/analytics/notifications/retry-bulk` — Bulk retry[m
[32m+[m[32m- `GET /admin/automation/logs` — Automation execution log[m
[32m+[m[32m- `POST /admin/automation/test` — Test automation rule[m
[32m+[m
[32m+[m[32m### Health Endpoints (Public)[m
[32m+[m[32m- `GET /api/v1/platform/health` — Platform health[m
[32m+[m[32m- `GET /api/v1/platform/providers/health` — Provider health[m
[32m+[m[32m- `GET /api/watchtower/*` — Operational monitoring[m
[32m+[m
[32m+[m[32m## Production Deployment[m
[32m+[m
[32m+[m[32m```bash[m
[32m+[m[32mphp artisan optimize:clear[m
[32m+[m[32mphp artisan config:cache[m
[32m+[m[32mphp artisan route:cache[m
[32m+[m[32mphp artisan event:cache[m
[32m+[m[32mphp artisan view:cache[m
[32m+[m[32mphp artisan queue:restart[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mProduction Environment[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32mAPP_ENV=production[m
[32m+[m[32mAPP_DEBUG=false[m
[32m+[m[32mLOG_LEVEL=error[m
[32m+[m[32mQUEUE_CONNECTION=database[m
[32m+[m[32mBROADCAST_CONNECTION=reverb[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mHealth Checks[m
[32m+[m
[32m+[m[32m```bash[m
[32m+[m[32mphp artisan queue:failed[m
[32m+[m[32mphp artisan about[m
[32m+[m[32mphp artisan route:list[m
[32m+[m[32mphp artisan test[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mRollback[m
[32m+[m
[32m+[m[32m```bash[m
[32m+[m[32mgit revert <commit>[m
[32m+[m[32mphp artisan optimize:clear[m
[32m+[m[32mphp artisan config:clear[m
[32m+[m[32mphp artisan route:clear[m
[32m+[m[32mphp artisan event:clear[m
[32m+[m[32m```[m
